# Optional — Dify advanced-chat (e.g. Agnes). Uses POST {VITE_DIFY_BASE_URL}/chat-messages.
# The app key is exposed in the browser bundle; use Dify app API keys only (app-...).
# This is NOT the dataset key (dataset-...).
VITE_DIFY_API_KEY=
VITE_DIFY_BASE_URL=https://api.dify.ai/v1
# Optional — only if your Dify app’s input variable is not named `query`
# VITE_DIFY_INPUT_QUERY_KEY=question
# Streaming SSE (opt-in). When unset/false, uses blocking mode (most compatible).
# VITE_DIFY_STREAMING=true
# Inputs: by default we send inputs.query = your message (Chatflow start variable).
# For truly empty inputs: VITE_DIFY_INPUT_QUERY_KEY=
# For another variable name: VITE_DIFY_INPUT_QUERY_KEY=your_variable

# Optional — absolute origin of FastAPI / ngrok (no trailing slash). If unset, dev uses Vite proxy to :8000.
# VITE_API_URL=https://your-tunnel.ngrok-free.dev
