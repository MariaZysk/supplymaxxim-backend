# Groq LLM credentials — get a key from https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Shared secret required by every /api/* request (sent as `X-API-Key` header).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty in local dev to disable auth (NOT recommended for any deployed instance).
SPHEREMAXXING_API_KEY=

# Comma-separated list of allowed CORS origins for the frontend.
# Example: https://spheremaxxing.lovable.app,http://localhost:8080
# Defaults to localhost dev origins when unset.
ALLOWED_ORIGINS=

# Agnes BOM API (uvicorn agnes.main:app) — optional overrides
# DB_PATH defaults to backend/data/db.sqlite
# DB_PATH=./data/db.sqlite
# FIRECRAWL_API_KEY=
# ENRICHMENT_CACHE_AGE_H=168
# PUBCHEM_CACHE_AGE_H=168
# REGULATORY_CACHE_AGE_H=72
# NEWS_CACHE_AGE_H=1
